# Copy to .env and fill in. NEVER commit the real .env.

# Long random string used to sign login tokens (change this!)
SECRET_KEY=change-me-to-a-long-random-secret

# Database. SQLite by default; for production PostgreSQL use e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/espanol
DATABASE_URL=sqlite:///./espanol.db

# Allowed frontend origins (comma separated). Use your domain in production.
# CORS_ORIGINS=https://espanol.tudominio.com
CORS_ORIGINS=*

# Hidden deploy: URL prefix (only if using nginx subpath). Example: /a1b2c3d4
# PUBLIC_PATH=/a1b2c3d4
# VITE_BASE_PATH=/a1b2c3d4/

# Calendar: day 1 unlocks on this date
PROGRAM_START_DATE=2026-07-01

# --- AI Text-to-Speech (Mexican accent). Optional. ---
# If empty, the app uses the browser's built-in es-MX voice for free.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_BASE_URL=https://api.openai.com/v1
